# ============================================================================
# Variaveis de ambiente para o docker-compose LOCAL — ERP Bem Comum
# ----------------------------------------------------------------------------
# Copie este arquivo para .env e ajuste se necessario:
#   cp .env.example .env
#
# Nenhum valor aqui eh utilizavel fora de DEV LOCAL. As senhas sao TRIVIAIS
# de proposito — sao publicas por design, nao ha segredo a proteger num banco
# efemero local. (Por isso esta camada nao usa SOPS.)
# ============================================================================

# --- MySQL ------------------------------------------------------------------
# Root para administracao local (phpMyAdmin, dumps, etc.). Os 3 usuarios de
# aplicacao sao criados pelo mysql/init.sql com senhas triviais fixas.
MYSQL_ROOT_PASSWORD=root_local_dev_only

# Porta exposta no host. Trocar se a 3306 ja estiver ocupada.
MYSQL_PORT=3306

# Porta do phpMyAdmin (so quando rodar com --profile tools).
PMA_PORT=8080

# --- Connection strings (mesmo formato de staging/prod, valores locais) ------
DATABASE_URL_CORE=mysql://core_app:core_local_dev_only@mysql:3306/core
# Usada SO pelo job de importacao do ERP antigo (nao ha servico em runtime).
DATABASE_URL_LEGACY=mysql://legacy_loader:legacy_local_dev_only@mysql:3306/legacy
DATABASE_URL_READONLY=mysql://readonly_bi:bi_local_dev_only@mysql:3306/

# --- MinIO (storage S3-compativel local) ------------------------------------
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=dev-access-key
MINIO_ROOT_PASSWORD=dev-secret-key-min-8-chars

# --- Borda HTTPS (Caddy) — usado pela stack completa (override no mono_repo) -
HTTP_PORT=80
HTTPS_PORT=443

# --- Seed do usuario de dev (login out-of-the-box na stack completa) ---------
SEED_EMAIL=admin@bemcomum.dev
SEED_PASSWORD=DevPassw0rd!2024

# --- Tags das imagens de aplicacao (quando subir via ghcr no repo publico) ---
CORE_API_TAG=dev
WEB_TAG=dev
