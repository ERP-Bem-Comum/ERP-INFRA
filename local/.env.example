# ============================================================================
# Variaveis de ambiente para o docker-compose LOCAL — ERP Bem Comum
# ----------------------------------------------------------------------------
# Copie este arquivo para .env e ajuste se necessario:
#   cp .env.example .env
#
# Nenhum valor aqui eh utilizavel fora de DEV LOCAL. As senhas sao triviais
# de proposito para nao haver risco de confusao com algum ambiente real.
# ============================================================================

# --- MySQL ------------------------------------------------------------------
# Root para administracao local (acesso phpMyAdmin, dumps, etc.)
MYSQL_ROOT_PASSWORD=root_local_dev_only

# Porta exposta no host. Trocar se a 3306 ja estiver ocupada.
MYSQL_PORT=3306

# Porta do phpMyAdmin (so quando rodar com --profile tools).
PMA_PORT=8080

# --- Connection strings dos servicos ----------------------------------------
# Mesmo formato esperado em staging/prod (do handbook), so com valores locais.
DATABASE_URL_LEGACY=mysql://legacy_app:legacy_local_dev_only@mysql:3306/legacy
DATABASE_URL_CORE=mysql://core_app:core_local_dev_only@mysql:3306/core
DATABASE_URL_READONLY=mysql://readonly_bi:bi_local_dev_only@mysql:3306/

# --- Auth / sessao (placeholders para quando os servicos forem descomentados)
# Substitua por valores aleatorios reais (openssl rand -hex 32) ao habilitar.
JWT_SIGNING_KEY=dev_only_jwt_signing_key_replace_me
SESSION_SECRET=dev_only_session_secret_replace_me

# --- Portas das aplicacoes (quando descomentar os servicos no compose) ------
BFF_PORT=8080
