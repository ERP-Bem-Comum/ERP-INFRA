{
  "family": "erp-prod-supplier-view-backfill",
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "networkMode": "awsvpc",
  "cpu": "256",
  "memory": "512",
  "runtimePlatform": {
    "cpuArchitecture": "X86_64",
    "operatingSystemFamily": "LINUX"
  },
  "executionRoleArn": "arn:aws:iam::<ACCOUNT_ID>:role/erp-prod-ecs-execution",
  "taskRoleArn": "arn:aws:iam::<ACCOUNT_ID>:role/erp-prod-job-task",
  "containerDefinitions": [
    {
      "name": "core-api",
      "image": "<ACCOUNT_ID>.dkr.ecr.<REGIAO>.amazonaws.com/core-api:sha-<commit>",
      "essential": true,
      "entryPoint": [
        "tini",
        "--",
        "node"
      ],
      "command": [
        "src/jobs/financial/supplier-view-backfill/run.ts"
      ],
      "environment": [
        {
          "name": "NODE_ENV",
          "value": "production"
        }
      ],
      "secrets": [
        {
          "name": "PARTNERS_DATABASE_URL",
          "valueFrom": "arn:aws:secretsmanager:<REGIAO>:<ACCOUNT_ID>:secret:erp/prod/PARTNERS_DATABASE_URL"
        },
        {
          "name": "FINANCIAL_DATABASE_URL",
          "valueFrom": "arn:aws:secretsmanager:<REGIAO>:<ACCOUNT_ID>:secret:erp/prod/FINANCIAL_DATABASE_URL"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/erp/prod/supplier-view-backfill",
          "awslogs-region": "<REGIAO>",
          "awslogs-stream-prefix": "job"
        }
      }
    }
  ],
  "tags": [
    {
      "key": "Environment",
      "value": "prod"
    },
    {
      "key": "Service",
      "value": "supplier-view-backfill"
    },
    {
      "key": "Type",
      "value": "job"
    },
    {
      "key": "Owner",
      "value": "infra"
    },
    {
      "key": "Repo",
      "value": "ERP-INFRA"
    }
  ]
}
