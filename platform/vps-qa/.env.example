# Imagens publicadas no ghcr pelos builds do GitHub Actions (deploy-qa.yml de cada repo).
# A VPS só puxa estas tags — nunca compila.
CORE_API_IMAGE=ghcr.io/erp-bem-comum/core-api:qa
WEB_IMAGE=ghcr.io/erp-bem-comum/bemcomum-web:qa

# FQDN público da API de QA. O Caddy emite o certificado TLS via ACME para este host
# (exige registro DNS A apontando para o IP público da VPS ANTES do primeiro start).
APP_ADDRESS=erp-qa.gabrieladeraldo.dev

# URL base usada pelo core-api (ex.: link de reset de senha). Normalmente https://<APP_ADDRESS>.
APP_URL=https://erp-qa.gabrieladeraldo.dev

# Origens permitidas no CORS (front que consome a API). Vazio = nenhuma origem cross-site.
CORS_ORIGINS=

# Storage de documentos (módulo contracts — ADR-0019/0021): object-storage da Magalu.
# As credenciais (S3_ACCESS_KEY_ID / S3_SECRET_ACCESS_KEY) NÃO vêm aqui — são secrets
# em ./secrets/s3-access-key-id e ./secrets/s3-secret-access-key.
S3_REGION=br-ne1
S3_BUCKET=erp-qa-documents
S3_ENDPOINT=https://br-ne1.magaluobjects.com
S3_FORCE_PATH_STYLE=true

# E-mail transacional (convite de novo usuário + reset de senha — ADR-0010).
# O Nodemailer só ativa com TODAS estas presentes (+ a senha em ./secrets/smtp-pass);
# faltando qualquer uma, o mailer fica no-op (não envia, boot segue).
SMTP_HOST=smtp.umbler.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@gabrieladeraldo.dev
AUTH_INVITE_FROM=Bem Comum <noreply@gabrieladeraldo.dev>
AUTH_RESET_FROM=Bem Comum <noreply@gabrieladeraldo.dev>

# Rate limit do login (opcional — defaults: 5 / "1 minute").
# AUTH_LOGIN_RATE_LIMIT_MAX=5
# AUTH_LOGIN_RATE_LIMIT_WINDOW=1 minute
