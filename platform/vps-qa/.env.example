# Crie um registro DNS A apontando para o IPv4 público. TLS é obrigatório para
# o cookie Secure usado no login.
APP_ADDRESS=qa.seudominio.com

# Imagens já construídas para linux/amd64. Podem ser tags locais após docker load
# ou referências de registry, por exemplo ghcr.io/org/core-api:sha.
CORE_API_IMAGE=core-api:qa
WEB_IMAGE=bemcomum-web:qa

# Use hexadecimal para não precisar escapar caracteres na URL do MySQL:
# openssl rand -hex 32
MYSQL_ROOT_PASSWORD=troque-por-um-segredo-forte
MYSQL_APP_PASSWORD=troque-por-outro-segredo-forte

# Contratos ficam em memória até o Object Storage ser configurado. Para persistir:
# 1. crie bucket e key exclusivos de QA na Magalu Object Storage;
# 2. preencha os S3_* abaixo;
# 3. altere CONTRACTS_DRIVER=mysql.
CONTRACTS_DRIVER=memory
S3_ENDPOINT=https://br-ne1.magaluobjects.com
S3_REGION=br-ne1
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=false
